{
    "compilerOptions": {
        "module": "NodeNext",
        "target": "ESNext",
        "lib": [
            "ESNext",
            "DOM",
            "DOM.Iterable"
        ],
        "declaration": true,
        "strict": true,
        "moduleResolution": "nodenext",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0",
        "outDir": "dist",
        "rootDir": "src"
    },
    "include": [
        "src"
    ]
}